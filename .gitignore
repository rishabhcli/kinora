# --- Secrets (never commit real keys) ---
.env
**/.env
# .env.example IS committed (it only contains placeholders)

# --- Python ---
.venv/
backend/.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage/
htmlcov/

# --- Node / monorepo ---
node_modules/
dist/
out/
.turbo/
*.tsbuildinfo

# legacy web frontend (to be retired)
frontend/dist/

# Electron build output
apps/desktop/release/
apps/desktop/dist-electron/

# Expo / React Native
.expo/

# --- Object storage / local artifacts ---
# Root-level runtime artifacts only; anchored so it does NOT match the real
# source tree at backend/app/storage/.
/storage/

# --- Logs ---
*.log

# --- OS ---
.DS_Store

# --- Claude Code local state ---
# Per-worktree Ralph loop state + local session files must never be committed:
# each agent worktree has its own .claude/ralph-loop.local.md and committing it
# would clobber sibling agents' state on merge. (agent-prompts/ mission MD is
# tracked; only the .claude/ inside any tree is ignored.)
.claude/
**/.claude/

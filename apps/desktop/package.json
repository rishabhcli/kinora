{
  "name": "@kinora/desktop",
  "productName": "Kinora",
  "version": "0.0.1",
  "private": true,
  "description": "Kinora - Watch the book",
  "license": "AGPL-3.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && node launch.cjs\"",
    "dev:electron": "tsc -p electron/tsconfig.json && node launch.cjs",
    "dev:web": "vite",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^12.41.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "postcss": "^8.4.49",
    "postcss-import": "15.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.4.11",
    "wait-on": "^8.0.0"
  }
}

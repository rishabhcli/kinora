{
  "name": "@kinora/desktop",
  "productName": "Kinora",
  "version": "0.0.1",
  "private": true,
  "description": "Kinora - Watch the book",
  "license": "AGPL-3.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && node launch.cjs\"",
    "dev:electron": "tsc -p electron/tsconfig.json && node launch.cjs",
    "dev:web": "vite",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && node src/test/run-node-tests.mjs && node electron/__tests__/run-electron-tests.mjs",
    "test:watch": "vitest",
    "test:a11y": "playwright test",
    "test:reading": "node src/test/run-node-tests.mjs",
    "e2e": "playwright test -c e2e/playwright.e2e.config.ts",
    "e2e:ui": "playwright test -c e2e/playwright.e2e.config.ts --ui",
    "e2e:headed": "playwright test -c e2e/playwright.e2e.config.ts --headed",
    "e2e:smoke": "playwright test -c e2e/playwright.e2e.config.ts --grep @smoke",
    "e2e:visual": "playwright test -c e2e/playwright.e2e.config.ts e2e/specs/visual.spec.ts",
    "e2e:update-snapshots": "playwright test -c e2e/playwright.e2e.config.ts --update-snapshots",
    "e2e:live": "KINORA_E2E_MOCK=0 KINORA_E2E_LIVE=1 playwright test -c e2e/playwright.e2e.config.ts",
    "e2e:typecheck": "tsc -p e2e/tsconfig.json --noEmit",
    "e2e:report": "playwright show-report test-results/e2e-report",
    "e2e:install-browsers": "playwright install --with-deps chromium",
    "test:electron": "node electron/__tests__/run-electron-tests.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.41.0",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "postcss-import": "15.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.0"
  }
}

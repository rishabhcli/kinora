{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "outDir": "../dist-electron",
    "rootDir": ".",
    "noEmit": false,
    "sourceMap": true,
    "strict": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": ["main.ts", "preload.ts", "shared/**/*.ts", "core/**/*.ts", "services/**/*.ts"],
  "exclude": ["__tests__/**", "**/*.test.ts"]
}

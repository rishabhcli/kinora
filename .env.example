# Kinora environment configuration (EXAMPLE)
#
# Copy the values you need into backend/.env for local development.
# backend/.env is gitignored and must hold the REAL DashScope key.
# This example file ONLY contains placeholders and is safe to commit.
#
# Variable names are case-insensitive and have no prefix (see app/core/config.py).

# --- Runtime ---
APP_ENV=local                     # local | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
SERVICE_NAME=kinora

# --- DashScope / Model Studio (Alibaba Cloud) ---
# REQUIRED. Get an intl key from Model Studio; never commit the real value.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com

# --- Reasoning provider (the agent crew's chat/brain) ---
# "dashscope" (default) keeps reasoning on Qwen. "openai" routes ALL reasoning
# agents (Showrunner/Adapter/Continuity/Cinematographer + §5.4 comment router)
# to OpenAI's GPT-5 line; image / TTS / Wan video stay on DashScope regardless.
# REASONING_MODEL is forced for every reasoning call (callers' Qwen ids ignored).
# NOTE: "gpt-5.6-terra" is not available on this account (verified 2026-06-28);
# gpt-5.5 is the latest GPT-5 reasoning model.
REASONING_PROVIDER=dashscope
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
REASONING_MODEL=gpt-5.5
REASONING_EFFORT=high
REASONING_MAX_OUTPUT_TOKENS=8192

# --- Model ids ---
CHAT_MODEL_MAX=qwen3.7-max
CHAT_MODEL_PLUS=qwen3.7-plus
CHAT_MODEL_ADAPTER=qwen3.5-plus
VL_MODEL=qwen-vl-max
IMAGE_MODEL=qwen-image-2.0-pro
IMAGE_EDIT_MODEL=qwen-image-edit-max
# Narration TTS model. qwen3-tts-flash serves the PRESET voices ingest assigns
# (e.g. Cherry, Ryan). qwen3-tts-vc is the voice-CLONE model (expects an enrolled
# voice; rejects preset ids), so keep TTS_MODEL on -flash for preset-voice narration.
TTS_MODEL=qwen3-tts-flash
TTS_CLONE_MODEL=qwen3-tts-vc
# Hosted Wan demo defaults. Quality overrides: t2v `wan2.5-t2v-preview`;
# i2v/r2v `wan2.2-i2v-plus`. Avoid `wan2.2-t2v-plus`: it accepts submission
# but has been observed failing at render on the intl endpoint.
VIDEO_MODEL=wan2.1-t2v-turbo
VIDEO_MODEL_I2V=wan2.1-i2v-turbo
VIDEO_MODEL_R2V=wan2.1-i2v-turbo
VIDEO_POLL_TIMEOUT_S=600
VIDEO_POLL_INTERVAL_S=3
VIDEO_POLL_MAX_INTERVAL_S=15

# --- Embeddings (shared image+text space for canon + episodic retrieval) ---
EMBED_MODEL_IMAGE=tongyi-embedding-vision-plus
EMBED_MODEL_TEXT=tongyi-embedding-vision-plus
EMBED_DIM=1152

# --- Postgres (async SQLAlchemy URL) ---
DATABASE_URL=postgresql+asyncpg://kinora:kinora@localhost:5432/kinora

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / object storage (MinIO locally, OSS/S3 in prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=kinora
S3_SECRET_KEY=kinora-secret
S3_BUCKET=kinora
# Public base URL for serving objects directly (leave unset to use signed URLs).
# S3_PUBLIC_BASE_URL=http://localhost:9000/kinora

# --- Scheduler watermarks / horizons (seconds of reading-time) ---
WATERMARK_LOW_S=25
WATERMARK_HIGH_S=75
COMMIT_HORIZON_S=45
SPEC_HORIZON_S=240

# --- Budget (video-seconds) ---
BUDGET_CEILING_VIDEO_S=1650
BUDGET_PER_SESSION_S=300
BUDGET_PER_SCENE_S=90
BUDGET_LOW_FLOOR_S=120

# --- Live video go-live gate (prevents silent credit burn while iterating) ---
KINORA_LIVE_VIDEO=false

# --- Concurrency lanes ---
CONCURRENCY_COMMITTED=4
CONCURRENCY_SPECULATIVE=2
CONCURRENCY_KEYFRAME=2
RETRY_CAP=2

# --- Ingest recovery ---
INGEST_RECOVERY_INTERVAL_S=30
INGEST_RECOVERY_LIMIT=25

# --- Auth (JWT) ---
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
ACCESS_TOKEN_TTL_S=86400

# --- Auth & security plane (app.auth / app.core.security, §6/§12) ---
# All optional with safe defaults; tighten in production. The production guard
# rejects the default JWT_SECRET (and an unset API_KEY_PEPPER is derived from it)
# outside APP_ENV=local.
# JWT_ISSUER=kinora
# JWT_AUDIENCE=kinora-api
# REFRESH_TOKEN_TTL_S=2592000          # 30 days; rotated on every use
# MFA_CHALLENGE_TTL_S=300
# PASSWORD_HASHER=bcrypt               # or "argon2" (if argon2-cffi installed)
# BCRYPT_ROUNDS=12
# PASSWORD_MIN_LENGTH=8
# PASSWORD_REQUIRE_UPPER=false         # tighten in prod
# PASSWORD_REQUIRE_LOWER=false
# PASSWORD_REQUIRE_DIGIT=false
# PASSWORD_REQUIRE_SYMBOL=false
# PASSWORD_BLOCK_COMMON=false          # set true in prod to deny common passwords
# LOGIN_MAX_FAILURES=5                 # account lockout threshold
# LOGIN_LOCKOUT_DURATION_S=900
# LOGIN_IP_MAX_ATTEMPTS=50             # coarse per-IP backstop (window below)
# LOGIN_IP_WINDOW_S=300
# MFA_ISSUER=Kinora
# TOTP_DRIFT_WINDOW=1                  # ±N 30s steps accepted (clock skew)
# RECOVERY_CODE_COUNT=10
# API_KEY_PEPPER=                      # set a real secret in prod (HMAC key)
# API_KEY_DEFAULT_TTL_S=               # blank == non-expiring
# MAX_SESSIONS_PER_USER=25
# CSRF_ENABLED=true
# CSRF_COOKIE_NAME=kinora_csrf
# CSRF_HEADER_NAME=X-CSRF-Token
# AUTH_AUDIT_RETENTION_DAYS=365

# --- MCP control surface (canon-memory server, §8.3) ---
# Required outside local; compose sets a dev token automatically.
# MCP_AUTH_TOKEN=kinora-local-dev-mcp-token

# --- CORS (JSON array of allowed origins) ---
CORS_ORIGINS=["http://localhost:5173"]

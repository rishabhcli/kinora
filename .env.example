# Kinora environment configuration (EXAMPLE)
#
# Copy the values you need into backend/.env for local development.
# backend/.env is gitignored and must hold the REAL DashScope key.
# This example file ONLY contains placeholders and is safe to commit.
#
# Variable names are case-insensitive and have no prefix (see app/core/config.py).

# --- Runtime ---
APP_ENV=local                     # local | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
SERVICE_NAME=kinora

# --- DashScope / Model Studio (Alibaba Cloud) ---
# REQUIRED. Get an intl key from Model Studio; never commit the real value.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com

# --- Model ids ---
CHAT_MODEL_MAX=qwen3.7-max
CHAT_MODEL_PLUS=qwen3.7-plus
CHAT_MODEL_ADAPTER=qwen3.5-plus
VL_MODEL=qwen-vl-max
IMAGE_MODEL=qwen-image-2.0-pro
IMAGE_EDIT_MODEL=qwen-image-edit-max
# Narration TTS model. qwen3-tts-flash serves the PRESET voices ingest assigns
# (e.g. Cherry, Ryan). qwen3-tts-vc is the voice-CLONE model (expects an enrolled
# voice; rejects preset ids), so keep this on -flash for preset-voice narration.
TTS_MODEL=qwen3-tts-flash
# NOTE: the Wan video model ids below are placeholders to be confirmed in the providers phase.
VIDEO_MODEL=wan2.7-t2v
VIDEO_MODEL_I2V=wan2.7-i2v
VIDEO_MODEL_R2V=wan2.7-r2v

# --- Postgres (async SQLAlchemy URL) ---
DATABASE_URL=postgresql+asyncpg://kinora:kinora@localhost:5432/kinora

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / object storage (MinIO locally, OSS/S3 in prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=kinora
S3_SECRET_KEY=kinora-secret
S3_BUCKET=kinora
# Public base URL for serving objects directly (leave unset to use signed URLs).
# S3_PUBLIC_BASE_URL=http://localhost:9000/kinora

# --- Scheduler watermarks / horizons (seconds of reading-time) ---
WATERMARK_LOW_S=25
WATERMARK_HIGH_S=75
COMMIT_HORIZON_S=45
SPEC_HORIZON_S=240

# --- Budget (video-seconds) ---
BUDGET_CEILING_VIDEO_S=1650
BUDGET_PER_SESSION_S=300
BUDGET_PER_SCENE_S=90
BUDGET_LOW_FLOOR_S=120

# --- Live video go-live gate (prevents silent credit burn while iterating) ---
KINORA_LIVE_VIDEO=false

# --- Concurrency lanes ---
CONCURRENCY_COMMITTED=4
CONCURRENCY_SPECULATIVE=2
CONCURRENCY_KEYFRAME=2
RETRY_CAP=2

# --- Auth (JWT) ---
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
ACCESS_TOKEN_TTL_S=86400

# --- CORS (JSON array of allowed origins) ---
CORS_ORIGINS=["http://localhost:5173"]

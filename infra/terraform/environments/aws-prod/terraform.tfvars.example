# Copy to terraform.tfvars (gitignored). AWS creds come from the standard chain
# (AWS_PROFILE / env / SSO), not from here.

region      = "ap-southeast-1"
environment = "prod" # prod | staging | dev — toggles HA/scale

admin_cidr = "203.0.113.0/24" # who can reach the ALB — never 0.0.0.0/0

s3_bucket_name = "kinora-prod-assets-UNIQUE"

db_password      = "ChangeMe-Complex-DB-1!"
redis_auth_token = "ChangeMe-At-Least-16-Chars-Long"

dashscope_api_key = "sk-..."

cors_origins = ["https://app.kinora.example.com"]

container_image          = "123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/kinora/backend:latest"
frontend_container_image = "123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/kinora/frontend:latest"

# jwt_secret / mcp_auth_token: leave unset to auto-generate (stored in Secrets Manager).

# Copy to terraform.tfvars (gitignored) and fill in. Secrets can also come from
# the ALICLOUD_ACCESS_KEY / ALICLOUD_SECRET_KEY env vars instead of this file.

# --- Credentials + region ---
alicloud_access_key = "LTAI_xxxxxxxxxxxxxxxxxxxx"
alicloud_secret_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
region              = "ap-southeast-1"
zones              = ["ap-southeast-1a", "ap-southeast-1b"]

# --- Naming ---
project     = "kinora"
environment = "prod"

# --- Network access control (no insecure defaults — you MUST set these) ---
# Use specific CIDRs (example values below are TEST-NET-3 docs ranges, not real).
# admin_cidr  -> who can reach the public API (8000): your frontend/LB or office egress.
# ssh_cidr    -> who can SSH (22): ideally a bastion/VPN /32. Kept separate from app access.
# The MCP port (8765) is locked to intra-VPC only in main.tf — it is never internet-facing.
admin_cidr = "203.0.113.10/32"
ssh_cidr   = "203.0.113.10/32"

# --- Application auth / CORS (the env the app now enforces in non-local) ---
# cors_origins   -> the deployed frontend origin(s); no "*" (credentialed CORS).
# jwt_secret     -> leave empty/commented to AUTO-GENERATE a strong secret (recommended).
# mcp_auth_token -> leave empty/commented to AUTO-GENERATE a strong bearer (recommended).
# Read the generated values after apply:
#   terraform output -raw jwt_secret
#   terraform output -raw mcp_auth_token
cors_origins = ["https://kinora.example.com"]
# jwt_secret     = ""
# mcp_auth_token = ""

# --- OSS (must be globally unique) ---
oss_bucket_name = "kinora-assets-yourorg"

# --- RDS PostgreSQL (region-specific class; >= 14 for pgvector) ---
rds_engine_version   = "16.0"
rds_instance_type    = "pg.n2.small.1"
rds_instance_storage = 50
# db_account_password = ""   # leave empty to auto-generate a strong one

# --- Tair / Redis (region-specific class) ---
redis_instance_class = "redis.master.small.default"
redis_engine_version = "7.0"
# redis_password      = ""   # leave empty to auto-generate

# --- ECS app tier ---
ecs_instance_type   = "ecs.g7.large"
ecs_password        = "Change-This-Str0ng-Passw0rd"
ingest_worker_count = 1
render_worker_count = 2

# --- Application runtime ---
container_image          = "registry.ap-southeast-1.aliyuncs.com/kinora/backend:latest"
frontend_container_image = "registry.ap-southeast-1.aliyuncs.com/kinora/frontend:latest"
dashscope_api_key        = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
kinora_live_video        = false # flip to true only when you intend to spend Wan video-seconds

# --- Hosted Wan video models (verified available on the DashScope-intl tier) ---
# Defaults are wan2.7; turbo (wan2.1-t2v-turbo / wan2.1-i2v-turbo) trades quality
# for lower latency. r2v rides the i2v model. Verify with provider_preflight.
video_model     = "wan2.7-t2v"
video_model_i2v = "wan2.7-i2v"
video_model_r2v = "wan2.7-i2v"

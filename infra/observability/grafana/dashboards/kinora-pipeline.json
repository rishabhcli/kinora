{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Kinora — Render pipeline & budget",
  "tags": ["kinora", "render", "budget"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Video-seconds spent (of 1650 ceiling)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "max": 1650,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1320 },
              { "color": "red", "value": 1650 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" },
      "targets": [
        { "expr": "kinora:video_seconds_spent:total", "legendFormat": "spent", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Accepted-footage efficiency (5m)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.7 }, { "color": "green", "value": 0.85 } ] }
        }
      },
      "targets": [ { "expr": "kinora:accepted_footage_ratio:5m", "refId": "A" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Regeneration rate (5m)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [ { "expr": "kinora:regen_rate:5m", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache hit ratio (5m)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [ { "expr": "kinora:cache_hit_ratio:5m", "refId": "A" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Render latency p50 / p95 by mode",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "kinora:render_latency_seconds:p50", "legendFormat": "p50 {{mode}}", "refId": "A" },
        { "expr": "kinora:render_latency_seconds:p95", "legendFormat": "p95 {{mode}}", "refId": "B" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queue depth by lane",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "kinora_queue_depth", "legendFormat": "{{lane}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Shots accepted vs degraded (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(kinora_shots_accepted_total[5m]))", "legendFormat": "accepted/s", "refId": "A" },
        { "expr": "sum(rate(kinora_shots_degraded_total[5m]))", "legendFormat": "degraded/s", "refId": "B" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Provider error ratio + DLQ growth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "kinora:provider_error_ratio:5m", "legendFormat": "provider err ratio", "refId": "A" },
        { "expr": "increase(kinora_dlq_total[15m])", "legendFormat": "DLQ /15m", "refId": "B" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Render mode mix (rate)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(kinora_render_mode_total[5m])) by (mode)", "legendFormat": "{{mode}}", "refId": "A" }
      ]
    }
  ]
}
